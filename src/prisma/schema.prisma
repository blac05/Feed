datasource db {
  provider = "mongodb"
  url      = env("mongodb+srv://Gibson:<db_password>@cluster0.udpjlbu.mongodb.net/?appName=Cluster0gggg--")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  email          String   @unique
  phoneNumber    String   @unique
  password       String
  username       String   @unique
  displayName    String
  profilePicture String?  @default("")
  isVerified     Boolean  @default(false) 
  pageType       String   @default("USER") // USER, COMPANY, SPORTS_CLUB, GOVT, SPONSOR
  followers      String[] @default([])
  following      String[] @default([])
  posts          Post[]
  tickets        Ticket[]
}

model Post {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  content          String
  category         String    
  mediaUrl         String?   @default("")
  authorId         String    @db.ObjectId
  author           User      @relation(fields: [authorId], references: [id])
  likes            String[]  @default([]) 
  reposts          String[]  @default([])
  commentsDisabled Boolean   @default(false)
  createdAt        DateTime  @default(now())
  comments         Comment[]
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  postId    String   @db.ObjectId
  post      Post     @relation(fields: [postId], references: [id])
  authorId  String   @db.ObjectId
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  date        DateTime
  location    String
  ticketPrice Float
  ticketsLeft Int
  tickets     Ticket[]
}

model Ticket {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String   @db.ObjectId
  event     Event    @relation(fields: [eventId], references: [id])
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}